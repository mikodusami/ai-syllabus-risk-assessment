# VT ARC LLM API Key
# Get yours at: https://llm.arc.vt.edu > User profile > Settings > Account > API keys
VT_ARC_API_KEY=sk-YOUR-API-KEY-HERE

# API Configuration
VT_ARC_API_BASE=https://llm-api.arc.vt.edu/api/v1

# Primary model: fast, no deep reasoning needed for short syllabi
VT_ARC_MODEL=Kimi-K2.6-non-thinking

# Fallback model: used when syllabus text exceeds primary model token limit
# Kimi-K2.6 default has thinking_token_budget: 4000 and handles larger context
VT_ARC_MODEL_FALLBACK=Kimi-K2.6
